{
  "name": "medusaclip-desktop",
  "version": "0.1.0",
  "description": "Medusa Clip — cortes virais de gameplay, rodando no seu PC",
  "main": "main.js",
  "author": "Medusa Clip",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.medusaclip.app",
    "productName": "Medusa Clip",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**"
    ],
    "extraResources": [
      {
        "from": "engine",
        "to": "engine"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video",
      "identity": null
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "AudioVideo"
    }
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2"
  }
}
