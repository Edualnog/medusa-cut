# Worker do Zorothax (SaaS). Copie pra .env (ignorado pelo git) e preencha.
# Os MESMOS valores do web/.env.local (server-side):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
KEY_ENCRYPTION_SECRET=

# Cloudflare R2 (storage dos clipes — S3-compativel)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=zorothax-clips

# --- LLM (ganchos + score) para rodar o motor manualmente (BYO key) ---
# Provedor: openrouter (padrao) | openai | anthropic
LLM_PROVIDER=openrouter
# Chave do provedor escolhido (sk-or-v1-... | sk-... | sk-ant-...)
LLM_API_KEY=
# opcional: sobrescrever modelos por etapa (defaults sao por provedor)
# LLM_MODEL=
# LLM_MODEL_TRIAGE=
# LLM_MODEL_JUDGE=
# LLM_BASE_URL=   # opcional (proxy / endpoint custom)

# opcional
# WORKER_POLL_SEC=5
# WORKER_CLIP_CAP=24
