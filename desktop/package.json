{
  "name": "medusaclip-desktop",
  "version": "0.1.21",
  "description": "Medusa Clip — cortes virais de gameplay, rodando no seu PC",
  "main": "main.js",
  "author": "Medusa Clip",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "//publish": "Releases sao publicadas NESTE mesmo repo publico (medusa-cut, source-available). electron-updater le este bloco pra achar o feed. Ver docs/SETUP.md.",
  "build": {
    "appId": "com.medusaclip.app",
    "productName": "Medusa Clip",
    "afterPack": "scripts/afterPack.js",
    "publish": [
      {
        "provider": "github",
        "owner": "Edualnog",
        "repo": "medusa-cut"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer/**"
    ],
    "extraResources": [
      {
        "from": "engine",
        "to": "engine"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video",
      "identity": null,
      "icon": "build/icon.icns",
      "artifactName": "MedusaClip-mac-${arch}.${ext}"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "MedusaClip-win-${arch}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "category": "AudioVideo",
      "icon": "build/icon.png",
      "artifactName": "MedusaClip-linux-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "electron-updater": "^6.8.9"
  }
}
