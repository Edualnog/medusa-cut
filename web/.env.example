# Variáveis do site (web/). Em produção, cadastre na Vercel
# (Settings → Environment Variables). Localmente, copie para web/.env.local.
# NUNCA commitar valores reais. .env.local é gitignored.

# Públicas (vão para o navegador) — seguras de expor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secreta (server-only) — usada apenas em app/api/* (runtime nodejs).
# Ignora a RLS: tratar como senha mestra. Nunca usar NEXT_PUBLIC, nunca no client/desktop.
SUPABASE_SERVICE_ROLE_KEY=
